# =============================================================================
# XOne - 生产环境变量模板
# =============================================================================
# 使用方式:
#   cp .env.example .env.production
#   vim .env.production   # 务必修改所有 *** 和 change-me 值！
# =============================================================================

# ---- 域名 (生产必填) ----
# SSL 证书将为此域名生成
DOMAIN=example.com

# ---- Certbot 通知邮箱 (SSL 证书续期通知) ----
CERTBOT_EMAIL=admin@example.com

# ---- 运行模式 ----
# production: 生产模式（禁用 Debug, 严格 CORS, 无热重载）
MODE=production

# ---- Uvicorn Worker 数量 ----
# 默认: 4。建议设置为服务器 CPU 核心数
WEB_CONCURRENCY=4

# ---- 应用密钥 ----
# 生成方式: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret-key

# =============================================================================
# PostgreSQL 数据库
# =============================================================================
POSTGRES_USER=xone
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=xone
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# =============================================================================
# MongoDB 数据库
# =============================================================================
MONGO_USER=admin
MONGO_PASSWORD=change-me-mongo-password
MONGO_DB=xone
MONGODB_URL=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@mongodb:27017

# =============================================================================
# Redis (缓存 / Celery Broker / 会话)
# =============================================================================
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

# =============================================================================
# 全文搜索 & AI
# =============================================================================

# Meilisearch（全文搜索）
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_KEY=change-me-meilisearch-master-key

# Qdrant（向量数据库 / RAG）
QDRANT_URL=http://qdrant:6333

# =============================================================================
# 对象存储 (MinIO / S3)
# =============================================================================
MINIO_URL=http://minio:9000
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_BUCKET=xone-prod

# =============================================================================
# 可选：第三方服务
# =============================================================================

# OpenAI / 兼容 API
# OPENAI_API_KEY=sk-***
# OPENAI_BASE_URL=https://api.openai.com/v1

# 邮件服务 (SMTP)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASSWORD=***
# SMTP_FROM=XOne <noreply@example.com>

# 日志级别 (debug, info, warning, error)
# LOG_LEVEL=info

# Sentry (错误追踪)
# SENTRY_DSN=https://***

# OAuth 2.0 提供商 (可选)
# GOOGLE_CLIENT_ID=***
# GOOGLE_CLIENT_SECRET=***
# GITHUB_CLIENT_ID=***
# GITHUB_CLIENT_SECRET=***
